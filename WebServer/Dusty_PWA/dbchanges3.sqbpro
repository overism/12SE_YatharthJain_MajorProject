<?xml version="1.0" encoding="UTF-8"?><sqlb_project><db path="" readonly="0" foreign_keys="" case_sensitive_like="" temp_store="" wal_autocheckpoint="" synchronous=""/><attached/><window><main_tabs open="structure browser pragmas query" current="1"/></window><tab_structure><column_width id="0" width="300"/><column_width id="1" width="0"/><column_width id="2" width="100"/><column_width id="3" width="3372"/><column_width id="4" width="0"/></tab_structure><tab_browse><table title="." custom_title="0" dock_id="2" table="0,0:"/><dock_state state="000000ff00000000fd00000001000000020000024800000213fc0100000002fb000000160064006f0063006b00420072006f00770073006500310100000000000002480000000000000000fb000000160064006f0063006b00420072006f00770073006500320100000000000002480000011800ffffff000002480000000000000004000000040000000800000008fc00000000"/><default_encoding codec=""/><browse_table_settings/></tab_browse><tab_sql><sql name="SQL 1*">CREATE TABLE IF NOT EXISTS &quot;tasks&quot; (
	&quot;taskID&quot; INTEGER PRIMARY KEY AUTOINCREMENT,
	&quot;userID&quot; INTEGER NOT NULL,
	&quot;subjectID&quot; INTEGER NOT NULL,
	&quot;title&quot; TEXT NOT NULL,
	&quot;description&quot; TEXT,
	&quot;duration&quot; INTEGER,
	&quot;dueDate&quot; DATETIME,
	&quot;taskType&quot; TEXT DEFAULT 'Homework',
	&quot;progress&quot; INTEGER DEFAULT 0,
	&quot;daysRemaining&quot; INTEGER DEFAULT 0,
	&quot;status&quot; TEXT DEFAULT 'pending' CHECK(&quot;status&quot; IN ('pending', 'in_progress', 'completed')),
	&quot;eventID&quot; INTEGER,
	&quot;createdAt&quot; DATETIME DEFAULT CURRENT_TIMESTAMP,
	FOREIGN KEY(&quot;userID&quot;) REFERENCES &quot;users&quot;(&quot;userID&quot;) ON DELETE CASCADE,
	FOREIGN KEY(&quot;subjectID&quot;) REFERENCES &quot;subjects&quot;(&quot;subjectID&quot;) ON DELETE CASCADE
);</sql><current_tab id="0"/></tab_sql></sqlb_project>
